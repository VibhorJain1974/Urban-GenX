# ============================================================
# Urban-GenX | .gitignore
# ============================================================

# Datasets (too large for GitHub)
data/raw/
data/processed/

# Checkpoints (too large)
checkpoints/*.pth
checkpoints/*.pth.corrupt

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
*.egg-info/

# Conda
.conda/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Kaggle credentials
kaggle.json

# Output and cache directories
.graphify-cache/
analysis-output/
logs/
dev/

# Training logs (optional — remove this line if you want to track them)
# TRAINING_LOG_*.txt
