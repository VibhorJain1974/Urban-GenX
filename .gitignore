# Create/overwrite .gitignore
@"
# Datasets (too large for GitHub)
data/raw/
data/processed/

# Checkpoints (too large)
checkpoints/*.pth

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv

# Conda
.conda/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Kaggle credentials
kaggle.json
"@ | Out-File -FilePath .gitignore -Encoding utf8
